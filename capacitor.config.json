{
  "appId": "com.calendar4jw.app",
  "appName": "Calendar4jw",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "App": {
      "handleUrlOpen": true
    },
    "GoogleAuth": {
      "scopes": ["profile", "email", "https://www.googleapis.com/auth/calendar"],
      "serverClientId": "149382287239-3vlds2tnv8l5hrludrhdbn5rabar1197.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    },
    "CapacitorHttp": {
      "enabled": true
    }
  },
  "android": {
    "intentFilters": [
      {
        "scheme": "calendar4jw"
      }
    ],
    "allowMixedContent": true
  }
}