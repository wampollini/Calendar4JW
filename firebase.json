{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/landing.html"
      },
      {
        "source": "/app/**",
        "destination": "/index.html"
      },
      {
        "source": "/app",
        "destination": "/index.html"
      }
    ]
  },
  "appDistribution": {
    "app": "android",
    "releaseNotesFile": "release-notes.txt"
  }
}
